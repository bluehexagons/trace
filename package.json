{
  "name": "trace",
  "version": "0.0.1",
  "description": "Trace - An esoteric, specialized, functional programming language",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./trace": {
      "types": "./dist/trace.d.ts",
      "browser": "./dist/trace.js",
      "import": "./dist/trace.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluehexagons/trace.git"
  },
  "keywords": [
    "esoteric",
    "language",
    "functional",
    "programming"
  ],
  "author": "bluehexagons",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bluehexagons/trace/issues"
  },
  "homepage": "https://github.com/bluehexagons/trace#readme",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
